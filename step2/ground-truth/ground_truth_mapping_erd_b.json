      "natural_key": [
        "passportNumber"
      ],
      "attributes": [
        {
          "source": "Passenger.pax_id",
          "maps_to": {
            "type": "property",
            "canonical_name": "passengerId",
            "role": "identifier"
          },
          "refinement": {
            "type": "interpretation",
            "note": "surrogate key; canonical natural key is passportNumber"
          }
        },
        {
          "source": "Passenger.full_name",
          "maps_to": {
            "type": "property",
            "canonical_name": "fullName",
            "role": "descriptive"
          },
          "refinement": {
            "type": "interpretation",
            "note": "coarser granularity than canonical firstName + lastName (ERD-A); cross-ERD name-granularity conflict"
