# Copy this file to ".env" (in this folder) and fill in your key.
# Required only for the LLM scenarios (1, 2, 3 and cross_llm / cross_llm_brief).
# The deterministic baselines (scenario 0 / cross_rule_based) need no key.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Temperature(s) for LLM runs. A single value = fixed temperature.
# Can be overridden per run with --temps / --repeats on the command line.
GEMINI_TEMPS=0.2
